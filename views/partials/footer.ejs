<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    setTimeout(function () {
        var alerts = document.querySelectorAll('.alert')
        alerts.forEach(function (alert) {
            var a = new bootstrap.Alert(alert)
            a.close()
        })
    }, 9000)
</script>
</body>

</html>